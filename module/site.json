  "change": [
    "({objForm, meta}) => {",
    "  const transect = meta.parents.sites_group;",
    "  // Si ces champs sont vides, on remplit avec les valeurs du transect.",
    "  [",
    "    'land_tenure', 'land_tenure_2',",
    "    'land_management', 'land_management_2'",
    "  ].forEach(prop => {",
    "    const form_value = objForm.value[prop];",
    "    if (form_value === null || form_value === undefined) {",
    "      const transect_value = transect.properties[prop]",
    "      if (",
    "        transect_value !== null",
    "        && transect_value !== undefined",
    "        && !objForm.controls[prop].dirty",
    "      ) {",
    "        objForm.patchValue({[prop]: transect_value});",
    "      }",
    "    }",
    "  });",
    "  ",
    "  // Réinitialise les champs d'habitats lorsque le niveau 1 est modifié.",
    "  ['main', 'secondary'].forEach(habitat_type => {",
    "    const level1_name = 'habitat_' + habitat_type + '_1';",
    "    const level1_value = objForm.controls[level1_name].value;",
    "    window.sterf_ebms ??= {};",
    "    window.sterf_ebms.prev ??= {};",
    "    window.sterf_ebms.prev['sec_' + level1_name] ??= level1_value;",
    "    if (level1_value != window.sterf_ebms.prev['sec_' + level1_name]) {",
    "      objForm.patchValue({",
    "        ['habitat_' + habitat_type + '_2']: null,",
    "        ['habitat_' + habitat_type + '_3']: null,",
    "        ['habitat_' + habitat_type + '_4']: null",
    "      });",
    "      window.sterf_ebms.prev['sec_' + level1_name] = level1_value;",
    "    }",
    "  });",
    "}"
  ]
