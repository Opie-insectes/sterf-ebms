    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B00",
      "mnemonique": "0",
      "label_default": "00. Calme",
      "label_en": "0. Smoke rises vertically",
      "definition_default": "La fumée monte verticalement. Les feuilles des arbres ne témoignent d'aucun mouvement."
    },
    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B01",
      "mnemonique": "1",
      "label_default": "01. Très légère brise",
      "label_en": "1. Slight smoke drift",
      "definition_default": "La fumée indique la direction du vent. Les girouettes ne s'orientent pas."
    },
    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B02",
      "mnemonique": "2",
      "label_default": "02. Légère brise",
      "label_en": "2. Wind felt on face, leaves rustle",
      "definition_default": "On sent le vent sur le visage. Les feuilles s'agitent. Les girouettes s'orientent."
    },
    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B03",
      "mnemonique": "3",
      "label_default": "03. Petite brise",
      "label_en": "3. Leaves and twigs in slight motion",
      "definition_default": "Les drapeaux flottent au vent. Les feuilles sont sans cesse en mouvement."
    },
    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B04",
      "mnemonique": "4",
      "label_default": "04. Jolie brise",
      "label_en": "4. Dust raised and small branches move",
      "definition_default": "Les poussières s'envolent. Les petites branches plient."
    },
    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B05",
      "mnemonique": "5",
      "label_default": "05. Bonne brise",
      "label_en": "5. Small trees in leaf begin to sway",
      "definition_default": "Le tronc des arbustes et arbrisseaux en feuilles balance. La cime de tous les arbres est agitée. Des vaguelettes se forment sur les eaux intérieures."
    },
    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B06",
      "mnemonique": "6",
      "label_default": "06. Vent frais",
      "label_en": "6. Large branches move and trees sway",
      "definition_default": "On entend siffler le vent. Les branches de large diamètre s'agitent. Les parapluies sont susceptibles de se retourner."
    },
    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B07",
      "mnemonique": "7",
      "label_default": "07. Grand frais",
      "definition_default": "Tous les arbres balancent. La marche contre le vent peut devenir difficile."
    },
    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B08",
      "mnemonique": "8",
      "label_default": "08. Coup de vent",
      "definition_default": "Les branches sont susceptibles de casser. La marche contre le vent est très difficile, voire impossible."
    },
    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B09",
      "mnemonique": "9",
      "label_default": "09. Fort coup de vent",
      "definition_default": "Le vent peut légèrement endommager les bâtiments : envols de tuiles, d'ardoises, chutes de cheminées."
    },
    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B10",
      "mnemonique": "10",
      "label_default": "10. Tempête",
      "definition_default": "Dégâts importants aux bâtiments. Les toits sont susceptibles de s'envoler. Certains arbres sont déracinés."
    },
    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B11",
      "mnemonique": "11",
      "label_default": "11. Violente tempête",
      "definition_default": "Ravages étendus et importants."
    },
    {
      "type": "BEAUFORT",
      "cd_nomenclature": "B12",
      "mnemonique": "12",
      "label_default": "12. Vent d'ouragan",
      "definition_default": "Dégâts très importants de l'ordre de la catastrophe naturelle."
    },
