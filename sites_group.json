  "specific": {
    "sites_group_code": {
      "attribut_label": "Code",
      "definition": "Code EBMS au format \"EBMS:France:XXX\" si le transect existe sur la plateforme eBMS ; laissez vide sinon.",
      "required": false
    },
    "uuid_sites_group": {
      "attribut_label": "UUID"
    },
    "id_digitiser": {
      "attribut_label": "Créateur·ice"
    },
    "first_use_date": {
      "attribut_label": "Date de première utilisation",
      "type_widget": "date",
      "required": true
    },
    "nb_sites": {
      "attribut_label": "Nombre de sections"
    },
    "width": {
      "type_widget": "nomenclature",
      "attribut_label": "Largeur des sections du transect",
      "code_nomenclature_type": "EBMS_TRN_WIDTH",
      "required": true,
      "type_util": "nomenclature",
      "value": {
        "code_nomenclature_type": "EBMS_TRN_WIDTH",
	"cd_nomenclature": "W05"
      }
    },
    "sensitivity": {
      "type_widget": "radio",
      "attribut_label": "Localisation sensible (eBMS uniquement)",
      "definition": "Est-ce que l'emplacement du transect doit ne pas être rendu public ? Cette notion de sensibilité ne s'appliquera que lors de la transmission des données à l'eBMS et ne concerne pas cette installation GeoNature.",
      "required": false,
      "values": ["Non", "Oui"],
      "value": "Non"
    },
    "habitat_main_1": {
      "type_widget": "nomenclature",
      "attribut_label": "Habitat principal (niveau 1)",
      "definition": "habitat principal à l'échelle du transect ; vous pouvez définir des habitats plus précis pour chaque section.",
      "link_definition":"https://www.vigienature.fr/sites/vigienature/files/atoms/files/sterf_classification_habitats.pdf",
      "code_nomenclature_type": "STERF_HAB_N1",
      "required": true,
      "type_util": "nomenclature"
    },
    "habitat_main_2": {
      "type_widget": "select",
      "attribut_label": "Habitat principal (niveau 2)",
      "required": true,
      "noNullOption": true,
      "values": [
        "({value, meta}) => {",
        "  const level1 = meta.nomenclatures[value.habitat_main_1];",
        "  if (level1 === undefined) return [];",
        "  const filterNomenclatures = (startsWith) =>",
        "    Object.values(meta.nomenclatures).filter(n => n.cd_nomenclature.startsWith(startsWith));",
        "  const mapToLabels = (nomenclatures) =>",
        "    nomenclatures.map(n => n.label_default);",
        "  switch (level1.cd_nomenclature) {",
        "    case 'HAB1_A':",
        "    case 'HAB1_B':",
        "      return mapToLabels(filterNomenclatures('HAB2_AB_'));",
        "    case 'HAB1_C':",
        "      return mapToLabels(filterNomenclatures('HAB2_C_'));",
        "    case 'HAB1_D':",
        "      return mapToLabels(filterNomenclatures('HAB2_D_'));",
        "    case 'HAB1_E':",
        "      return mapToLabels(filterNomenclatures('HAB2_E_'));",
        "    case 'HAB1_G':",
        "      return mapToLabels(filterNomenclatures('HAB2_G_'));",
        "  }",
        "  return []",
        "}"
      ]
    },
    "habitat_main_3": {
      "type_widget": "select",
      "attribut_label": "Habitat principal (niveau 3), optionnel",
      "required": false,
      "values": [
        "({value, meta}) => {",
        "  const level1 = meta.nomenclatures[value.habitat_main_1];",
        "  if (level1 === undefined) return [];",
        "  const filterNomenclatures = (startsWith) =>",
        "    Object.values(meta.nomenclatures).filter(n => n.cd_nomenclature.startsWith(startsWith));",
        "  const mapToLabels = (nomenclatures) =>",
        "    nomenclatures.map(n => n.label_default);",
        "  switch (level1.cd_nomenclature) {",
        "    case 'HAB1_A':",
        "      return mapToLabels(filterNomenclatures('HAB3_A_'));",
        "    case 'HAB1_B':",
        "      return mapToLabels(filterNomenclatures('HAB3_B_'));",
        "    case 'HAB1_C':",
        "      return mapToLabels(filterNomenclatures('HAB3_C_'));",
        "    case 'HAB1_D':",
        "      return mapToLabels(filterNomenclatures('HAB3_D_'));",
        "    case 'HAB1_E':",
        "      return mapToLabels(filterNomenclatures('HAB3_E_'));",
        "    case 'HAB1_G':",
